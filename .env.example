# Firebase Identity Toolkit API key — used for store-manager sign-in and token refresh.
# Each Firebase project has its own key. Use the project that matches your BE environment.
VITE_FIREBASE_API_KEY=

# Backend API base URL.
# REQUIRED in deployed environments (Vercel) so calls do not fall back to the
# /api rewrite in vercel.json. Each Vercel project (production, staging) must
# set this explicitly to its own gateway URL.
#
#   Production : https://<prod-gateway-url>           (TBD — awaiting BE)
#   Staging    : https://monnalisa-mid-dev-api-gw-1lcvs0vu.ew.gateway.dev
#   Local dev  : leave EMPTY — the Vite proxy in vite.config.ts handles /api
VITE_API_BASE_URL=
