# =============================================================================
# Frontend (Vite) build-time vars — must start with VITE_, exposed to bundle.
# =============================================================================

# Firebase Identity Toolkit API key — used for store-manager sign-in and token
# refresh. Each Firebase project has its own key. Use the project that matches
# your BE environment (prod Firebase ↔ prod gateway).
VITE_FIREBASE_API_KEY=

# Frontend base URL for BE calls.
# Leave EMPTY in normal cases — the FE will hit /api/* on the same origin and
# the Vercel Edge Function (api/[...path].ts) proxies to BE_BASE_URL.
# Only set this if you want to bypass the proxy and call a gateway directly
# (e.g. local development against a custom backend with CORS enabled).
VITE_API_BASE_URL=

# =============================================================================
# Vercel Edge Function server-side var — NO VITE_ prefix, NOT in the bundle.
# =============================================================================

# Backend API gateway URL the proxy forwards to. Configure this PER Vercel
# project so prod and staging hit different gateways:
#   Production project  → BE_BASE_URL=https://<prod-gateway>            (TBD — awaiting BE)
#   Staging project     → BE_BASE_URL=https://monnalisa-mid-dev-api-gw-1lcvs0vu.ew.gateway.dev
# Local dev does NOT need this — the Vite proxy in vite.config.ts handles /api.
BE_BASE_URL=
